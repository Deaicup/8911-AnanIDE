{
  "name": "@anan/theia-app",
  "version": "0.0.0",
  "private": true,
  "description": "Theia application configuration for Anan IDE",
  "dependencies": {
    "@theia/core": "^1.49.0",
    "@theia/editor": "^1.49.0",
    "@theia/file-search": "^1.49.0",
    "@theia/filesystem": "^1.49.0",
    "@theia/markers": "^1.49.0",
    "@theia/monaco": "^1.49.0",
    "@theia/terminal": "^1.49.0",
    "@theia/workspace": "^1.49.0",
    "@anan/anan-ui": "0.0.0",
    "@anan/anan-mcp": "0.0.0",
    "@anan/anan-core": "0.0.0"
  },
  "scripts": {
    "build": "npm run bundle && npm run patch:drivelist",
    "bundle": "npm run rebuild && theia build --mode development",
    "patch:drivelist": "node ../../scripts/patch-theia-drivelist.js",
    "rebuild": "theia rebuild:browser --cacheRoot ../..",
    "dev": "npm run build && npm run start",
    "start": "theia start --hostname 0.0.0.0 --port 3000",
    "watch": "npm run rebuild && theia build --watch --mode development",
    "clean": "rimraf lib dist .theia"
  },
  "devDependencies": {
    "@theia/cli": "^1.49.0"
  },
  "theia": {
    "target": "browser",
    "frontend": {
      "config": {
        "applicationName": "8911 安安黏糊开发机",
        "defaultTheme": "anan-pink"
      }
    }
  }
}
