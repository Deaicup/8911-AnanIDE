{
  "name": "anan-ide",
  "version": "0.0.0",
  "private": true,
  "description": "8911 安安黏糊开发机 - 二次元风格 AI 开发软件",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "lerna clean && lerna run clean",
    "build": "lerna run build --stream",
    "dev": "lerna run dev --stream --parallel",
    "dev:theia": "npm run dev -w @anan/theia-app",
    "dev:electron": "npm run dev -w @anan/electron",
    "test": "npm run test:unit",
    "test:unit": "jest --config tests/unit/jest.config.js",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "smoke": "npm run smoke:electron-config && npm run smoke:theia",
    "smoke:theia": "node scripts/smoke/theia-smoke.js",
    "smoke:electron-config": "node scripts/smoke/electron-config-smoke.js",
    "lint": "eslint \"packages/*/src/**/*.ts\"",
    "check": "npm run lint && npm run test:unit && npm run build && npm run smoke:electron-config",
    "package:dir": "npm run build && electron-builder --dir --config electron-builder.yml",
    "package:win": "npm run build && electron-builder --win --config electron-builder.yml",
    "rebuild:native": "npm rebuild better-sqlite3 electron",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "lerna": "^8.1.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
